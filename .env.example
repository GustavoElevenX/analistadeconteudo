# ==============================
# OPENAI
# ==============================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ==============================
# APIFY
# ==============================
APIFY_API_TOKEN=
APIFY_ACTOR_GOOGLE_SEARCH=apify/google-search-scraper
APIFY_ACTOR_INSTAGRAM=apify/instagram-scraper
APIFY_ACTOR_LINKEDIN_SEARCH=harvestapi/linkedin-post-search
APIFY_ACTOR_LINKEDIN=harvestapi/postagens-de-perfil-do-linkedin

# Use | para separar varios itens.
APIFY_GOOGLE_QUERIES="gestao comercial B2B Brasil"|"vendas B2B tendencias Brasil"|"lideranca comercial pipeline CRM"|"forecast vendas B2B"|"funil de vendas B2B"
APIFY_INSTAGRAM_URLS=
APIFY_INSTAGRAM_HASHTAGS=vendasb2b|gestaocomercial|liderancacomercial|crm|prospeccao
APIFY_LINKEDIN_SEARCH_QUERIES="gestao comercial"|"vendas B2B"|"lideranca comercial"|"forecast vendas"|"pipeline de vendas"|"CRM vendas"|"funil de vendas"
APIFY_LINKEDIN_PROFILE_URLS=

APIFY_GOOGLE_RESULTS_LIMIT=20
APIFY_INSTAGRAM_RESULTS_LIMIT=20
APIFY_LINKEDIN_SEARCH_POSTS_LIMIT=10
APIFY_LINKEDIN_POSTS_LIMIT=10

# ==============================
# WHATSAPP (CallMeBot)
# ==============================
CALLMEBOT_PHONE=
CALLMEBOT_APIKEY=

# ==============================
# SCHEDULER
# ==============================
CRON_SCRAPE_AND_GENERATE=0 0 * * *
CRON_WHATSAPP_BRIEFING=0 7 * * *
TIMEZONE=America/Sao_Paulo

# ==============================
# SERVIDOR
# ==============================
PORT=3000
NODE_ENV=production
APP_PUBLIC_URL=http://localhost:3000
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=troque-essa-senha

# ==============================
# CRIADOR (contexto do sistema)
# ==============================
CREATOR_NAME=
CREATOR_PARTNER=Pedro
CREATOR_PRODUCT=
CREATOR_CTA_LINK=
CREATOR_BIO=
CREATOR_HAS_CASES=false

# ==============================
# CONFIGURACOES DE GERACAO
# ==============================
DAILY_CONTENT_LIMIT=20
BRIEFING_TOP_PICKS=5

# ==============================
# INSTAGRAM GRAPH API (metricas)
# ==============================
IG_ACCESS_TOKEN=
IG_USER_ID=
IG_TOKEN_REFRESH_DAYS=50

# ==============================
# SCHEDULER - METRICAS E APRENDIZADO
# ==============================
CRON_METRICS_SYNC=0 */2 * * *
CRON_INTELLIGENCE_UPDATE=0 3 * * *
CRON_WEEKLY_REPORT=0 8 * * 1
METRICS_MIN_AGE_HOURS=2
INTELLIGENCE_WINDOW_DAYS=30
